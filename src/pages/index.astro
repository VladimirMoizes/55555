---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <div class="image-container">
    <img
      src="/assets/images/car_big.png"
      alt="Big car"
      class="car-image"
      id="movingCar"
    />
    <hr class="solid-line" />
    <img
      src="/assets/images/line_dashed.svg"
      alt="Dashed line"
      class="line-image"
    />
  </div>
</MainLayout>

<style>
  .image-container {
    position: relative;
    width: 100%;
    min-height: 500px;
    height: 100%;
    overflow: hidden;
  }

  .car-image {
    position: absolute;
    bottom: 136px;
    left: 0;
    width: 678px;
    height: auto;
    z-index: 3;
    cursor: pointer;
    transition: transform 2s ease-in-out;
  }

  .car-image.moving {
    transform: translateX(calc(100vw - 339px));
  }

  .solid-line {
    position: absolute;
    bottom: 240px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--color-primary);
    border: none;
    z-index: 2;
  }

  .line-image {
    position: absolute;
    bottom: 131px;
    right: 20px;
    width: 100%;
    height: auto;
    z-index: 2;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const car = document.getElementById('movingCar');

    if (car) {
      car.addEventListener('click', function () {
        this.classList.add('moving');

        setTimeout(() => {
          this.classList.remove('moving');
        }, 3000);
      });
    }
  });
</script>
